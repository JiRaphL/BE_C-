@startuml
left to right direction
title Use Case 3 - Dynamiques de population et regles metier

actor "Moteur de simulation" as System
actor "Evaluateur" as Reviewer

rectangle "Dynamique des bestioles" {
  usecase "Creer la population initiale" as UC1
  usecase "Appliquer un comportement\ndynamique" as UC2
  usecase "Detecter les voisins" as UC3
  usecase "Gerer les collisions" as UC4
  usecase "Faire vieillir les bestioles" as UC5
  usecase "Cloner une bestiole" as UC6
  usecase "Declencher une naissance\nspontanee" as UC7
  usecase "Retirer les bestioles mortes" as UC8
}

System --> UC1
System --> UC2
System --> UC4
System --> UC5
System --> UC6
System --> UC7
System --> UC8
Reviewer --> UC2
Reviewer --> UC4

UC2 .> UC3 : <<include>>
UC5 .> UC8 : <<extend>>
UC6 .> UC8 : <<extend>>
UC7 .> UC8 : <<extend>>

@enduml
