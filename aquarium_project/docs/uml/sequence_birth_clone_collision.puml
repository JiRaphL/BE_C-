@startuml
title Sequence - Collisions, Morts, Naissances, Clonage

participant Milieu
participant CollisionManager
participant LifecycleManager
participant BestioleFactory
participant Bestiole as Parent
participant Bestiole as Clone
participant Bestiole as Newborn

Milieu -> CollisionManager : resolve(population)
alt collision détectée
  CollisionManager -> Parent : kill() ou demiTour()
  CollisionManager -> Parent : kill() ou demiTour() (autre bestiole)
end
CollisionManager --> Milieu : collisions + deathsByCollision

Milieu -> LifecycleManager : ageAndCull(population)
alt age >= maxAge
  LifecycleManager -> Parent : kill()
end
LifecycleManager --> Milieu : deathsByAge

Milieu -> LifecycleManager : processBirthsAndClones(population, factory, w, h)
loop pour chaque bestiole vivante
  LifecycleManager -> BestioleFactory : tryCreateClone(parent)
  alt clonage accepté
    BestioleFactory --> LifecycleManager : Clone
    LifecycleManager -> Clone : initializeNewborn(age=0,maxAge=random)
    LifecycleManager -> Clone : setCoords(parent.x,parent.y)
  end
end

LifecycleManager -> BestioleFactory : tryCreateSpontaneousBirth()
alt naissance spontanée acceptée
  BestioleFactory --> LifecycleManager : Newborn
  LifecycleManager -> Newborn : initializeNewborn(age=0,maxAge=random)
  LifecycleManager -> Newborn : initCoords(w,h)
end
LifecycleManager --> Milieu : birthsByClone + birthsSpontaneous

@enduml
