@startuml
left to right direction
title Use Case 1 - Configurer et executer une simulation

actor "Operateur" as User
actor "Evaluateur" as Reviewer

rectangle "Simulation Bestioles" {
  usecase "Configurer la simulation\n(population, comportements,\ncapteurs, accessoires,\ncollisions, cycle de vie)" as UC1
  usecase "Initialiser la population" as UC2
  usecase "Lancer la simulation" as UC3
  usecase "Visualiser l'aquarium" as UC4
  usecase "Mettre en pause / reprendre" as UC5
  usecase "Arreter la simulation" as UC6
}

User --> UC1
User --> UC3
User --> UC4
User --> UC5
User --> UC6
Reviewer --> UC4

UC3 .> UC1 : <<include>>
UC3 .> UC2 : <<include>>
UC4 .> UC5 : <<extend>>
UC4 .> UC6 : <<extend>>

@enduml
